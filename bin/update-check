#!/usr/bin/env bash

set -euo pipefail

REPO_PATH=""
BRANCH=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        repo_path) REPO_PATH="${2:-}"; shift 2 ;;
        branch) BRANCH="${2:-}"; shift 2 ;;
        *) echo "Unknown argument: $1" >&2; exit 2 ;;
    esac
done

if [[ -z "$REPO_PATH" || -z "$BRANCH" ]]; then
    echo "Usage: update-check repo_path <path> branch <branch>" >&2
    exit 2
fi

if [[ "$BRANCH" =~ [^a-zA-Z0-9._/-] ]]; then
    echo "Invalid branch: $BRANCH" >&2
    exit 2
fi

cd "$REPO_PATH"

if [[ ! -d .git ]]; then
    echo '{"ok":false,"error":"not a git repository"}'
    exit 1
fi

REMOTE="$(git remote | head -n 1 || true)"

if [[ -z "$REMOTE" ]]; then
    echo '{"ok":false,"error":"no git remote configured"}'
    exit 1
fi

CURRENT="$(git rev-parse HEAD)"
git fetch "$REMOTE" "$BRANCH" --quiet
REMOTE_REF="$REMOTE/$BRANCH"
LATEST="$(git rev-parse "$REMOTE_REF")"
BEHIND="$(git rev-list --count "HEAD..$REMOTE_REF")"
AHEAD="$(git rev-list --count "$REMOTE_REF..HEAD")"
DIRTY="$(git status --porcelain)"

printf '{"ok":true,"remote":"%s","branch":"%s","current":"%s","latest":"%s","behind":%s,"ahead":%s,"dirty":%s,"update_available":%s}\n' \
    "$REMOTE" \
    "$BRANCH" \
    "$CURRENT" \
    "$LATEST" \
    "$BEHIND" \
    "$AHEAD" \
    "$( [[ -n "$DIRTY" ]] && echo true || echo false )" \
    "$( [[ "$BEHIND" != "0" ]] && echo true || echo false )"
