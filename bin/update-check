#!/usr/bin/env bash

set -euo pipefail

REPO_PATH=""
REPOSITORY_URL=""
BRANCH=""
CACHE_PATH=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        repo_path) REPO_PATH="${2:-}"; shift 2 ;;
        repository_url) REPOSITORY_URL="${2:-}"; shift 2 ;;
        branch) BRANCH="${2:-}"; shift 2 ;;
        cache_path) CACHE_PATH="${2:-}"; shift 2 ;;
        *) echo "Unknown argument: $1" >&2; exit 2 ;;
    esac
done

if [[ -z "$REPO_PATH" || -z "$REPOSITORY_URL" || -z "$BRANCH" || -z "$CACHE_PATH" ]]; then
    echo "Usage: update-check repo_path <path> repository_url <url> branch <branch> cache_path <path>" >&2
    exit 2
fi

if [[ "$BRANCH" =~ [^a-zA-Z0-9._/-] ]]; then
    echo "Invalid branch: $BRANCH" >&2
    exit 2
fi

EXPECTED_CACHE="$REPO_PATH/var/update-cache/repo"

if [[ "$CACHE_PATH" != "$EXPECTED_CACHE" ]]; then
    echo "Cache path must be $EXPECTED_CACHE" >&2
    exit 2
fi

mkdir -p "$(dirname "$CACHE_PATH")"

if [[ ! -d "$CACHE_PATH/.git" ]]; then
    rm -rf -- "$CACHE_PATH"
    git clone --quiet --branch "$BRANCH" "$REPOSITORY_URL" "$CACHE_PATH"
fi

cd "$CACHE_PATH"

CURRENT="$(git -c safe.directory="$CACHE_PATH" rev-parse HEAD)"
git -c safe.directory="$CACHE_PATH" remote set-url origin "$REPOSITORY_URL"
git -c safe.directory="$CACHE_PATH" fetch origin "$BRANCH" --quiet
REMOTE_REF="origin/$BRANCH"
LATEST="$(git -c safe.directory="$CACHE_PATH" rev-parse "$REMOTE_REF")"
BEHIND="$(git -c safe.directory="$CACHE_PATH" rev-list --count "HEAD..$REMOTE_REF")"
AHEAD="$(git -c safe.directory="$CACHE_PATH" rev-list --count "$REMOTE_REF..HEAD")"
DIRTY="$(git -c safe.directory="$CACHE_PATH" status --porcelain)"
APP_VERSION="$(git -C "$REPO_PATH" rev-parse HEAD 2>/dev/null || echo unknown)"

printf '{"ok":true,"remote":"origin","repository_url":"%s","branch":"%s","app_path":"%s","cache_path":"%s","app_version":"%s","current":"%s","latest":"%s","behind":%s,"ahead":%s,"dirty":%s,"update_available":%s}\n' \
    "$REPOSITORY_URL" \
    "$BRANCH" \
    "$REPO_PATH" \
    "$CACHE_PATH" \
    "$APP_VERSION" \
    "$CURRENT" \
    "$LATEST" \
    "$BEHIND" \
    "$AHEAD" \
    "$( [[ -n "$DIRTY" ]] && echo true || echo false )" \
    "$( [[ "$CURRENT" != "$LATEST" ]] && echo true || echo false )"
