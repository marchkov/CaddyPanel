#!/usr/bin/env bash

set -euo pipefail

REPO_PATH=""
REPOSITORY_URL=""
BRANCH=""
CACHE_PATH=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        repo_path) REPO_PATH="${2:-}"; shift 2 ;;
        repository_url) REPOSITORY_URL="${2:-}"; shift 2 ;;
        branch) BRANCH="${2:-}"; shift 2 ;;
        cache_path) CACHE_PATH="${2:-}"; shift 2 ;;
        *) echo "Unknown argument: $1" >&2; exit 2 ;;
    esac
done

if [[ -z "$REPO_PATH" || -z "$REPOSITORY_URL" || -z "$BRANCH" || -z "$CACHE_PATH" ]]; then
    echo "Usage: update-apply repo_path <path> repository_url <url> branch <branch> cache_path <path>" >&2
    exit 2
fi

if [[ "$BRANCH" =~ [^a-zA-Z0-9._/-] ]]; then
    echo "Invalid branch: $BRANCH" >&2
    exit 2
fi

EXPECTED_CACHE="$REPO_PATH/var/update-cache/repo"

if [[ "$CACHE_PATH" != "$EXPECTED_CACHE" ]]; then
    echo "Cache path must be $EXPECTED_CACHE" >&2
    exit 2
fi

mkdir -p "$(dirname "$CACHE_PATH")"

if [[ ! -d "$CACHE_PATH/.git" ]]; then
    rm -rf -- "$CACHE_PATH"
    git clone --quiet --branch "$BRANCH" "$REPOSITORY_URL" "$CACHE_PATH"
fi

cd "$CACHE_PATH"
git -c safe.directory="$CACHE_PATH" remote set-url origin "$REPOSITORY_URL"
git -c safe.directory="$CACHE_PATH" fetch origin "$BRANCH" --quiet
git -c safe.directory="$CACHE_PATH" checkout --quiet "$BRANCH"
git -c safe.directory="$CACHE_PATH" reset --hard "origin/$BRANCH" --quiet

TARGET_REV="$(git -c safe.directory="$CACHE_PATH" rev-parse HEAD)"

rsync -a --delete \
    --exclude ".git" \
    --exclude "apps/***" \
    --exclude "config/secret.key" \
    --exclude "config/mariadb-service.cnf" \
    --exclude "var/data/***" \
    --exclude "var/generated/***" \
    --exclude "var/backups/***" \
    --exclude "var/logs/***" \
    --exclude "var/update-cache/***" \
    ./ "$REPO_PATH/"

chmod 755 "$REPO_PATH/bin/post-update"
"$REPO_PATH/bin/post-update" app_dir "$REPO_PATH" target_rev "$TARGET_REV"

echo "updated panel code to $TARGET_REV"
