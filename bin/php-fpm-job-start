#!/usr/bin/env bash

set -euo pipefail

JOB_ID=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        job_id) JOB_ID="${2:-}"; shift 2 ;;
        *) echo "Unknown argument: $1" >&2; exit 2 ;;
    esac
done

if [[ ! "$JOB_ID" =~ ^[0-9]+$ ]]; then
    echo "Usage: php-fpm-job-start job_id <id>" >&2
    exit 2
fi

APP_DIR="/opt/caddypanel"
WORKER="$APP_DIR/bin/php-fpm-job-worker.php"

if [[ ! -f "$WORKER" ]]; then
    echo "PHP-FPM job worker not found: $WORKER" >&2
    exit 1
fi

mkdir -p "$APP_DIR/var/logs"
nohup /usr/bin/php "$WORKER" job_id "$JOB_ID" >> "$APP_DIR/var/logs/php-version-jobs.log" 2>&1 &

echo "Started PHP-FPM job #$JOB_ID."
