#!/usr/bin/env bash

set -euo pipefail

service_status() {
    local service="$1"

    if systemctl is-active --quiet "$service"; then
        echo "active"
    elif systemctl list-unit-files "${service}.service" --no-legend 2>/dev/null | grep -q "${service}.service"; then
        systemctl is-active "$service" 2>/dev/null || true
    else
        echo "unknown"
    fi
}

php_fpm_services_json() {
    local service
    local status
    local first=1

    printf '['

    while IFS= read -r service; do
        service="${service%.service}"
        status="$(service_status "$service")"

        if [[ "$first" -eq 0 ]]; then
            printf ','
        fi

        first=0
        printf '{"service":"%s","status":"%s"}' "$service" "$status"
    done < <(systemctl list-unit-files 'php*-fpm.service' --no-legend 2>/dev/null | awk '{print $1}' | sort -V)

    printf ']'
}

php_fpm_summary() {
    local services_json="$1"

    if [[ "$services_json" == *'"status":"active"'* ]]; then
        echo "active"
    elif [[ "$services_json" == "[]" ]]; then
        echo "unknown"
    else
        echo "inactive"
    fi
}

CADDY_STATUS="$(service_status caddy)"
PHP_FPM_SERVICES="$(php_fpm_services_json)"
PHP_STATUS="$(php_fpm_summary "$PHP_FPM_SERVICES")"
MARIADB_STATUS="$(service_status mariadb)"
DISK_USAGE="$(df -h / | awk 'NR==2 {print $3 "/" $2 " (" $5 ")"}')"

printf '{"caddy":"%s","php_fpm":"%s","php_fpm_services":%s,"mariadb":"%s","disk":"%s"}\n' \
    "$CADDY_STATUS" \
    "$PHP_STATUS" \
    "$PHP_FPM_SERVICES" \
    "$MARIADB_STATUS" \
    "$DISK_USAGE"
