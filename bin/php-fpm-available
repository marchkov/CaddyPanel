#!/usr/bin/env bash

set -euo pipefail

if ! command -v apt-cache >/dev/null 2>&1; then
    printf '[]\n'
    exit 0
fi

first=1
printf '['

while IFS= read -r package; do
    version="${package#php}"
    version="${version%-fpm}"

    if [[ ! "$version" =~ ^[0-9]+\.[0-9]+$ ]]; then
        continue
    fi

    candidate="$(apt-cache policy "$package" 2>/dev/null | awk '/Candidate:/ {print $2; exit}')"

    if [[ -z "$candidate" || "$candidate" == "(none)" ]]; then
        continue
    fi

    if [[ "$first" -eq 0 ]]; then
        printf ','
    fi

    first=0
    printf '{"version":"%s","package":"%s","candidate":"%s"}' "$version" "$package" "$candidate"
done < <(apt-cache search --names-only '^php[0-9]+\.[0-9]+-fpm$' 2>/dev/null | awk '{print $1}' | sort -Vu)

printf ']\n'
