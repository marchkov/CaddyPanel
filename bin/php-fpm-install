#!/usr/bin/env bash

set -euo pipefail

if [[ "${1:-}" == "version" ]]; then
    VERSION="${2:-}"
else
    VERSION="${1:-}"
fi

if [[ ! "$VERSION" =~ ^[0-9]+\.[0-9]+$ ]]; then
    echo "Usage: php-fpm-install <major.minor>" >&2
    exit 2
fi

if ! command -v apt-get >/dev/null 2>&1; then
    echo "apt-get is not available." >&2
    exit 2
fi

packages=(
    "php${VERSION}-fpm"
    "php${VERSION}-cli"
    "php${VERSION}-common"
    "php${VERSION}-sqlite3"
    "php${VERSION}-mysql"
    "php${VERSION}-mbstring"
    "php${VERSION}-xml"
    "php${VERSION}-curl"
    "php${VERSION}-zip"
    "php${VERSION}-gd"
    "php${VERSION}-intl"
)

configure_systemd_access() {
    local service="php${VERSION}-fpm"
    local dropin_dir="/etc/systemd/system/${service}.service.d"

    if ! command -v systemctl >/dev/null 2>&1; then
        return
    fi

    mkdir -p "$dropin_dir"
    cat > "$dropin_dir/caddypanel.conf" <<'EOF'
[Service]
ReadWritePaths=/etc/caddy /etc/caddy/sites /opt/caddypanel /var/www/sites /var/log/caddypanel
EOF

    systemctl daemon-reload
}

apt-get install -y "${packages[@]}"
apt-mark manual "${packages[@]}" >/dev/null
configure_systemd_access

if command -v systemctl >/dev/null 2>&1; then
    systemctl enable --now "php${VERSION}-fpm" >/dev/null 2>&1 || true
fi

echo "Installed PHP ${VERSION} FPM runtime and configured CaddyPanel systemd write paths."
