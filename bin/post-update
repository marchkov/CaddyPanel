#!/usr/bin/env bash

set -euo pipefail

APP_DIR=""
TARGET_REV=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        app_dir) APP_DIR="${2:-}"; shift 2 ;;
        target_rev) TARGET_REV="${2:-}"; shift 2 ;;
        *) echo "Unknown argument: $1" >&2; exit 2 ;;
    esac
done

if [[ -z "$APP_DIR" || -z "$TARGET_REV" ]]; then
    echo "Usage: post-update app_dir <path> target_rev <sha>" >&2
    exit 2
fi

if [[ "$APP_DIR" != "/opt/caddypanel" ]]; then
    echo "App dir must be /opt/caddypanel" >&2
    exit 2
fi

DB_PATH="$APP_DIR/var/data/caddypanel.sqlite"

if [[ ! -f "$DB_PATH" ]]; then
    echo "Database not found: $DB_PATH" >&2
    exit 2
fi

run_schema_updates() {
    if [[ -f "$APP_DIR/database/schema.sql" ]]; then
        sqlite3 "$DB_PATH" < "$APP_DIR/database/schema.sql"
    fi

    sqlite3 "$DB_PATH" <<'SQL'
CREATE TABLE IF NOT EXISTS schema_migrations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    migration TEXT NOT NULL UNIQUE,
    applied_at TEXT NOT NULL
);
SQL

    if [[ -d "$APP_DIR/database/migrations" ]]; then
        while IFS= read -r migration; do
            name="$(basename "$migration")"

            if [[ ! "$name" =~ ^[a-zA-Z0-9._-]+\.sql$ ]]; then
                echo "Invalid migration filename: $name" >&2
                exit 2
            fi

            applied="$(sqlite3 "$DB_PATH" "SELECT 1 FROM schema_migrations WHERE migration = '$name' LIMIT 1;")"

            if [[ "$applied" == "1" ]]; then
                continue
            fi

            sqlite3 "$DB_PATH" < "$migration"
            sqlite3 "$DB_PATH" "INSERT INTO schema_migrations (migration, applied_at) VALUES ('$name', datetime('now'));"
        done < <(find "$APP_DIR/database/migrations" -maxdepth 1 -type f -name '*.sql' | sort)
    fi
}

ensure_default_settings() {
    sqlite3 "$DB_PATH" <<'SQL'
INSERT OR IGNORE INTO settings (key, value, created_at, updated_at)
VALUES
    ('session_lifetime', '3600', datetime('now'), datetime('now')),
    ('security_ip_allowlist', '', datetime('now'), datetime('now')),
    ('health_check_token', '', datetime('now'), datetime('now'));

INSERT INTO settings (key, value, created_at, updated_at)
SELECT 'panel_php_version', COALESCE((SELECT value FROM settings WHERE key = 'default_php_version'), '8.4'), datetime('now'), datetime('now')
WHERE NOT EXISTS (SELECT 1 FROM settings WHERE key = 'panel_php_version');

INSERT INTO settings (key, value, created_at, updated_at)
SELECT 'panel_php_fpm_socket', COALESCE((SELECT value FROM settings WHERE key = 'default_php_fpm_socket'), '/run/php/php8.4-fpm.sock'), datetime('now'), datetime('now')
WHERE NOT EXISTS (SELECT 1 FROM settings WHERE key = 'panel_php_fpm_socket');
SQL
}

ensure_default_modules() {
    sqlite3 "$DB_PATH" <<'SQL'
INSERT OR IGNORE INTO modules (name, enabled, config_json, created_at, updated_at)
VALUES
    ('admin_tasks', 1, NULL, datetime('now'), datetime('now')),
    ('firewall', 1, NULL, datetime('now'), datetime('now'));
SQL
}

configure_sudoers() {
    if [[ -f "$APP_DIR/install/sudoers.tpl" ]]; then
        if ! cp "$APP_DIR/install/sudoers.tpl" /etc/sudoers.d/caddypanel; then
            echo "warning: unable to update /etc/sudoers.d/caddypanel; privileged helpers may need manual sudoers refresh" >&2
            return 0
        fi

        if ! chmod 440 /etc/sudoers.d/caddypanel; then
            echo "warning: unable to chmod /etc/sudoers.d/caddypanel" >&2
            return 0
        fi

        if ! visudo -cf /etc/sudoers.d/caddypanel >/dev/null; then
            echo "warning: updated sudoers file did not pass validation" >&2
            return 0
        fi
    fi
}

configure_cron() {
    mkdir -p "$APP_DIR/var/logs"
    chown -R www-data:www-data "$APP_DIR/var/logs"

    if ! cat > /etc/cron.d/caddypanel <<EOF
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

* * * * * www-data cd $APP_DIR && APP_ENV=production /usr/bin/php $APP_DIR/bin/backup-scheduler.php >> $APP_DIR/var/logs/backup-scheduler.log 2>&1
0 * * * * www-data cd $APP_DIR && APP_ENV=production /usr/bin/php $APP_DIR/bin/update-cron.php >> $APP_DIR/var/logs/update-cron.log 2>&1
EOF
    then
        echo "warning: unable to update /etc/cron.d/caddypanel; scheduled tasks may need manual cron refresh" >&2
        return 0
    fi

    if ! chmod 644 /etc/cron.d/caddypanel; then
        echo "warning: unable to chmod /etc/cron.d/caddypanel" >&2
        return 0
    fi

    if command -v systemctl >/dev/null 2>&1; then
        systemctl enable --now cron >/dev/null 2>&1 || true
        systemctl restart cron >/dev/null 2>&1 || true
    fi
}

configure_cli() {
    if [[ -f "$APP_DIR/bin/cdpanel" ]]; then
        if ! ln -sf "$APP_DIR/bin/cdpanel" /usr/local/bin/cdpanel; then
            echo "warning: unable to update /usr/local/bin/cdpanel symlink" >&2
        fi
    fi
}

panel_php_fpm_service() {
    local socket

    socket="$(sqlite3 "$DB_PATH" "SELECT value FROM settings WHERE key='panel_php_fpm_socket' LIMIT 1;" 2>/dev/null || true)"

    if [[ -z "$socket" ]]; then
        socket="$(sqlite3 "$DB_PATH" "SELECT value FROM settings WHERE key='default_php_fpm_socket' LIMIT 1;" 2>/dev/null || true)"
    fi

    if [[ "$socket" =~ php([0-9]+\.[0-9]+)-fpm\.sock ]]; then
        echo "php${BASH_REMATCH[1]}-fpm"
        return
    fi

    systemctl list-unit-files 'php*-fpm.service' --no-legend 2>/dev/null | awk '{print $1}' | sed 's/\.service$//' | sort -V | tail -n 1
}

configure_php_fpm_systemd_access() {
    local service
    local dropin_dir

    if ! command -v systemctl >/dev/null 2>&1; then
        return 0
    fi

    service="$(panel_php_fpm_service)"

    if [[ -z "$service" ]]; then
        echo "warning: unable to detect panel PHP-FPM service for systemd access override" >&2
        return 0
    fi

    dropin_dir="/etc/systemd/system/${service}.service.d"

    if ! mkdir -p "$dropin_dir"; then
        echo "warning: unable to create $dropin_dir" >&2
        return 0
    fi

    if ! cat > "$dropin_dir/caddypanel.conf" <<'EOF'
[Service]
ReadWritePaths=/etc/caddy /etc/caddy/sites /opt/caddypanel /var/www/sites /var/log/caddypanel
EOF
    then
        echo "warning: unable to update PHP-FPM systemd override for $service" >&2
        return 0
    fi

    systemctl daemon-reload >/dev/null 2>&1 || true
}

render_panel_caddy_config() {
    local domain socket template tmp

    template="$APP_DIR/caddy/templates/panel.caddy.tpl"

    if [[ ! -f "$template" ]]; then
        echo "warning: panel Caddy template missing: $template" >&2
        return 0
    fi

    domain="$(sqlite3 "$DB_PATH" "SELECT value FROM settings WHERE key='panel_domain' LIMIT 1;" 2>/dev/null || true)"
    socket="$(sqlite3 "$DB_PATH" "SELECT value FROM settings WHERE key='panel_php_fpm_socket' LIMIT 1;" 2>/dev/null || true)"

    if [[ -z "$domain" ]]; then
        domain="localhost"
    fi

    if [[ -z "$socket" ]]; then
        socket="$(sqlite3 "$DB_PATH" "SELECT value FROM settings WHERE key='default_php_fpm_socket' LIMIT 1;" 2>/dev/null || true)"
    fi

    if [[ -z "$socket" ]]; then
        socket="/run/php/php8.4-fpm.sock"
    fi

    if ! mkdir -p /etc/caddy/sites; then
        echo "warning: unable to create /etc/caddy/sites" >&2
        return 0
    fi

    tmp="$(mktemp)"
    awk -v domain="$domain" -v socket="$socket" '{
        gsub(/\{panel_domain\}/, domain)
        gsub(/\{panel_php_fpm_socket\}/, socket)
        print
    }' "$template" > "$tmp"

    if [[ -f /etc/caddy/sites/caddypanel.caddy ]]; then
        cp /etc/caddy/sites/caddypanel.caddy "/etc/caddy/sites/caddypanel.caddy.bak.$(date +%Y%m%d%H%M%S)" || true
    fi

    if ! cp "$tmp" /etc/caddy/sites/caddypanel.caddy; then
        echo "warning: unable to update /etc/caddy/sites/caddypanel.caddy" >&2
    fi

    rm -f "$tmp"
}

fix_permissions() {
    chown -R www-data:www-data "$APP_DIR"
    chown -R root:root "$APP_DIR/bin"
    find "$APP_DIR/bin" -type f -exec chmod 755 {} \;

    chown root:www-data "$APP_DIR/config"
    chmod 750 "$APP_DIR/config"

    if [[ -f "$APP_DIR/config/secret.key" ]]; then
        chown root:www-data "$APP_DIR/config/secret.key"
        chmod 640 "$APP_DIR/config/secret.key"
    fi

    if [[ -f "$APP_DIR/config/mariadb-service.cnf" ]]; then
        chown root:www-data "$APP_DIR/config/mariadb-service.cnf"
        chmod 640 "$APP_DIR/config/mariadb-service.cnf"
    fi
}

record_version() {
    sqlite3 "$DB_PATH" <<SQL
INSERT INTO settings (key, value, created_at, updated_at)
VALUES ('app_version', '$TARGET_REV', datetime('now'), datetime('now'))
ON CONFLICT(key) DO UPDATE SET value = excluded.value, updated_at = excluded.updated_at;
SQL
}

run_schema_updates
ensure_default_settings
ensure_default_modules
configure_sudoers
configure_cron
fix_permissions
configure_cli
configure_php_fpm_systemd_access
render_panel_caddy_config
record_version

echo "post-update completed for $TARGET_REV"
