#!/usr/bin/env bash

set -euo pipefail

APP_DIR=""
TARGET_REV=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        app_dir) APP_DIR="${2:-}"; shift 2 ;;
        target_rev) TARGET_REV="${2:-}"; shift 2 ;;
        *) echo "Unknown argument: $1" >&2; exit 2 ;;
    esac
done

if [[ -z "$APP_DIR" || -z "$TARGET_REV" ]]; then
    echo "Usage: post-update app_dir <path> target_rev <sha>" >&2
    exit 2
fi

if [[ "$APP_DIR" != "/opt/caddypanel" ]]; then
    echo "App dir must be /opt/caddypanel" >&2
    exit 2
fi

DB_PATH="$APP_DIR/var/data/caddypanel.sqlite"

if [[ ! -f "$DB_PATH" ]]; then
    echo "Database not found: $DB_PATH" >&2
    exit 2
fi

run_schema_updates() {
    if [[ -f "$APP_DIR/database/schema.sql" ]]; then
        sqlite3 "$DB_PATH" < "$APP_DIR/database/schema.sql"
    fi

    sqlite3 "$DB_PATH" <<'SQL'
CREATE TABLE IF NOT EXISTS schema_migrations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    migration TEXT NOT NULL UNIQUE,
    applied_at TEXT NOT NULL
);
SQL

    if [[ -d "$APP_DIR/database/migrations" ]]; then
        while IFS= read -r migration; do
            name="$(basename "$migration")"

            if [[ ! "$name" =~ ^[a-zA-Z0-9._-]+\.sql$ ]]; then
                echo "Invalid migration filename: $name" >&2
                exit 2
            fi

            applied="$(sqlite3 "$DB_PATH" "SELECT 1 FROM schema_migrations WHERE migration = '$name' LIMIT 1;")"

            if [[ "$applied" == "1" ]]; then
                continue
            fi

            sqlite3 "$DB_PATH" < "$migration"
            sqlite3 "$DB_PATH" "INSERT INTO schema_migrations (migration, applied_at) VALUES ('$name', datetime('now'));"
        done < <(find "$APP_DIR/database/migrations" -maxdepth 1 -type f -name '*.sql' | sort)
    fi
}

ensure_default_settings() {
    sqlite3 "$DB_PATH" <<'SQL'
INSERT OR IGNORE INTO settings (key, value, created_at, updated_at)
VALUES
    ('session_lifetime', '3600', datetime('now'), datetime('now')),
    ('security_ip_allowlist', '', datetime('now'), datetime('now')),
    ('health_check_token', '', datetime('now'), datetime('now'));
SQL
}

ensure_default_modules() {
    sqlite3 "$DB_PATH" <<'SQL'
INSERT OR IGNORE INTO modules (name, enabled, config_json, created_at, updated_at)
VALUES
    ('admin_tasks', 1, NULL, datetime('now'), datetime('now')),
    ('firewall', 1, NULL, datetime('now'), datetime('now'));
SQL
}

configure_sudoers() {
    if [[ -f "$APP_DIR/install/sudoers.tpl" ]]; then
        if ! cp "$APP_DIR/install/sudoers.tpl" /etc/sudoers.d/caddypanel; then
            echo "warning: unable to update /etc/sudoers.d/caddypanel; privileged helpers may need manual sudoers refresh" >&2
            return 0
        fi

        if ! chmod 440 /etc/sudoers.d/caddypanel; then
            echo "warning: unable to chmod /etc/sudoers.d/caddypanel" >&2
            return 0
        fi

        if ! visudo -cf /etc/sudoers.d/caddypanel >/dev/null; then
            echo "warning: updated sudoers file did not pass validation" >&2
            return 0
        fi
    fi
}

configure_cron() {
    mkdir -p "$APP_DIR/var/logs"
    chown -R www-data:www-data "$APP_DIR/var/logs"

    if ! cat > /etc/cron.d/caddypanel <<EOF
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

* * * * * www-data cd $APP_DIR && APP_ENV=production /usr/bin/php $APP_DIR/bin/backup-scheduler.php >> $APP_DIR/var/logs/backup-scheduler.log 2>&1
0 * * * * www-data cd $APP_DIR && APP_ENV=production /usr/bin/php $APP_DIR/bin/update-cron.php >> $APP_DIR/var/logs/update-cron.log 2>&1
EOF
    then
        echo "warning: unable to update /etc/cron.d/caddypanel; scheduled tasks may need manual cron refresh" >&2
        return 0
    fi

    if ! chmod 644 /etc/cron.d/caddypanel; then
        echo "warning: unable to chmod /etc/cron.d/caddypanel" >&2
        return 0
    fi

    if command -v systemctl >/dev/null 2>&1; then
        systemctl enable --now cron >/dev/null 2>&1 || true
        systemctl restart cron >/dev/null 2>&1 || true
    fi
}

fix_permissions() {
    chown -R www-data:www-data "$APP_DIR"
    chown -R root:root "$APP_DIR/bin"
    find "$APP_DIR/bin" -type f -exec chmod 755 {} \;

    chown root:www-data "$APP_DIR/config"
    chmod 750 "$APP_DIR/config"

    if [[ -f "$APP_DIR/config/secret.key" ]]; then
        chown root:www-data "$APP_DIR/config/secret.key"
        chmod 640 "$APP_DIR/config/secret.key"
    fi

    if [[ -f "$APP_DIR/config/mariadb-service.cnf" ]]; then
        chown root:www-data "$APP_DIR/config/mariadb-service.cnf"
        chmod 640 "$APP_DIR/config/mariadb-service.cnf"
    fi
}

record_version() {
    sqlite3 "$DB_PATH" <<SQL
INSERT INTO settings (key, value, created_at, updated_at)
VALUES ('app_version', '$TARGET_REV', datetime('now'), datetime('now'))
ON CONFLICT(key) DO UPDATE SET value = excluded.value, updated_at = excluded.updated_at;
SQL
}

run_schema_updates
ensure_default_settings
ensure_default_modules
configure_sudoers
configure_cron
fix_permissions
record_version

echo "post-update completed for $TARGET_REV"
