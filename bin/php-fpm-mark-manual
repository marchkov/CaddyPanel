#!/usr/bin/env bash

set -euo pipefail

if [[ "${1:-}" == "version" ]]; then
    VERSION="${2:-}"
else
    VERSION="${1:-}"
fi

if [[ ! "$VERSION" =~ ^[0-9]+\.[0-9]+$ ]]; then
    echo "Usage: php-fpm-mark-manual <major.minor>" >&2
    exit 2
fi

if ! command -v apt-mark >/dev/null 2>&1; then
    echo "apt-mark is not available." >&2
    exit 2
fi

run_host_command() {
    if command -v systemd-run >/dev/null 2>&1 && [[ -d /run/systemd/system ]]; then
        systemd-run --quiet --wait --collect --pipe --service-type=exec "$@"
        return
    fi

    "$@"
}

packages=(
    "php${VERSION}-fpm"
    "php${VERSION}-cli"
    "php${VERSION}-common"
    "php${VERSION}-sqlite3"
    "php${VERSION}-mysql"
    "php${VERSION}-mbstring"
    "php${VERSION}-xml"
    "php${VERSION}-curl"
    "php${VERSION}-zip"
    "php${VERSION}-gd"
    "php${VERSION}-intl"
)

installed=()

for package in "${packages[@]}"; do
    if dpkg-query -W -f='${Status}' "$package" 2>/dev/null | grep -q 'install ok installed'; then
        installed+=("$package")
    fi
done

if [[ "${#installed[@]}" -eq 0 ]]; then
    echo "No installed PHP ${VERSION} packages were found." >&2
    exit 1
fi

run_host_command apt-mark manual "${installed[@]}"
